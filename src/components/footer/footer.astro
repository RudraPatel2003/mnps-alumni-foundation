---
import { socialMediaLinks } from "../shared-content/social-media-links";
import FooterDisclaimer from "./footer-disclaimer.astro";
import FooterHeader from "./footer-header.astro";
import FooterLink from "./footer-link.astro";
import FooterLogo from "./footer-logo.astro";

const { facebookLink, instagramLink, linkedinLink } = socialMediaLinks;
---

<section class="min-h-70 bg-primary pt-16 text-white">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 gap-y-10 max-md:pb-4 md:grid-cols-10">
      <div class="md:col-span-5">
        <FooterLogo />
      </div>

      <div class="hidden md:col-span-1 md:block"></div>

      <div class="md:col-span-2">
        <FooterHeader title="Learn More" />
        <ul class="list-none space-y-1 p-0">
          <li>
            <FooterLink href="/connecting-alumni" text="Connecting Alumni" />
          </li>
          <li>
            <FooterLink href="/sharing-stories" text="Sharing Stories" />
          </li>
          <li>
            <FooterLink href="/funding-futures" text="Funding Futures" />
          </li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <FooterHeader title="Follow us" />
        <ul class="list-none space-y-1 p-0">
          <li>
            <FooterLink
              href={facebookLink}
              text="Facebook"
              attributes={{ target: "_blank", rel: "noreferrer" }}
            />
          </li>
          <li>
            <FooterLink
              href={instagramLink}
              text="Instagram"
              attributes={{ target: "_blank", rel: "noreferrer" }}
            />
          </li>
          <li>
            <FooterLink
              href={linkedinLink}
              text="LinkedIn"
              attributes={{ target: "_blank", rel: "noreferrer" }}
            />
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-white/20 py-6">
      <FooterDisclaimer />
    </div>
  </div>
</section>
