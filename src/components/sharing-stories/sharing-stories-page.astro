---
import { getInvolvedLink } from "../shared-content/get-involved-link";
import Button from "../ui/button.astro";
---

<section class="w-full py-16">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <p
        class="text-sm font-semibold tracking-[0.3em] text-secondary uppercase"
      >
        Coming Soon
      </p>
      <h1 class="mt-4 font-serif text-4xl text-primary md:text-5xl">
        Sharing <span class="display-accent">Stories</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-primary/80">
        We're developing a space to celebrate the voices and achievements of
        MNPS alumni. Soon, you'll find inspiring stories, spotlights, and
        opportunities to share your own journey.
      </p>
    </div>

    <div
      class="mt-14 rounded-2xl bg-primary/15 p-8 text-center ring-1 ring-primary/10 sm:p-10"
    >
      <p class="mx-auto max-w-xl text-lg leading-relaxed text-primary/80">
        In the meantime, help us get started. Join the network and nominate a
        special alumni story. We can't wait to highlight our alumni community!
      </p>
      <div class="mt-6 flex justify-center">
        <Button
          href={getInvolvedLink}
          target="_blank"
          rel="noopener noreferrer"
        >
          Join the Alumni Network
        </Button>
      </div>
    </div>
  </div>
</section>
