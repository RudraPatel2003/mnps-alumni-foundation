---
import { getInvolvedLink } from "../shared-content/get-involved-link";
import Button from "../ui/button.astro";
import HamburgerIcon from "./hamburger-icon.astro";
import NavigationLink from "./navigation-link.astro";
import NavigationLogo from "./navigation-logo.astro";
---

<div class="flex items-center justify-between nav:hidden">
  <NavigationLogo />
  <details class="relative">
    <summary
      class="cursor-pointer list-none rounded-md p-2 text-primary transition-colors duration-300 hover:text-secondary"
    >
      <HamburgerIcon />
    </summary>
    <div
      class="absolute right-0 mt-3 w-56 rounded-lg border border-secondary/10 bg-white p-5 shadow-lg"
    >
      <ul class="flex flex-col gap-4 text-left">
        <NavigationLink href="/connecting-alumni"
          >CONNECTING ALUMNI</NavigationLink
        >
        <NavigationLink href="/sharing-stories">
          SHARING STORIES
        </NavigationLink>
        <NavigationLink href="/funding-futures">FUNDING FUTURES</NavigationLink>
        <li>
          <Button
            href={getInvolvedLink}
            target="_blank"
            rel="noopener noreferrer"
          >
            GET INVOLVED
          </Button>
        </li>
      </ul>
    </div>
  </details>
</div>
