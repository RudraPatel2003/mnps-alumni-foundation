---
import Button from "../../ui/button.astro";

type Props = {
  title: string;
  subtitle: string;
  description: string;
  href: string;
};

export type PillarInformation = Props;

const { title, subtitle, description, href } = Astro.props;
---

<article
  class="flex h-full flex-col rounded-2xl bg-primary p-8 text-white shadow-lg ring-1 ring-white/10 transition duration-300"
>
  <h3 class="font-serif text-2xl">{title}</h3>
  <span class="mt-3 block h-0.5 w-10 rounded-full bg-secondary"></span>
  <p class="mt-4 text-base font-semibold text-white/90">{subtitle}</p>
  <p class="mt-3 text-base leading-relaxed text-white/85">{description}</p>
  <div class="mt-auto pt-8">
    <Button href={href} variant="secondary"> LEARN MORE </Button>
  </div>
</article>
