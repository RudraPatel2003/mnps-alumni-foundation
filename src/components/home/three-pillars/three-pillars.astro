---
import Pillar, { type PillarInformation } from "./pillar.astro";
import { threePillarsContent } from "./three-pillars-content";

const {
  connectingAlumniContent,
  sharingStoriesContent,
  fundingFuturesContent,
} = threePillarsContent;

const pillars: PillarInformation[] = [
  {
    title: "Connecting Alumni",
    subtitle: "Stay Connected. Stay MNPS.",
    description: connectingAlumniContent,
    href: "/connecting-alumni",
  },
  {
    title: "Sharing Stories",
    subtitle: "Celebrating Alumni Voices.",
    description: sharingStoriesContent,
    href: "/sharing-stories",
  },
  {
    title: "Funding Futures",
    subtitle: "Turning Alumni Pride into Student Opportunity.",
    description: fundingFuturesContent,
    href: "/funding-futures",
  },
];
---

<section class="w-full py-16">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-serif text-3xl text-primary md:text-4xl">
        Our Three <span class="display-accent">Pillars</span>
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-primary/70">
        Three ways we connect, celebrate, and invest in MNPS alumni.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        pillars.map((pillar) => (
          <Pillar
            title={pillar.title}
            subtitle={pillar.subtitle}
            description={pillar.description}
            href={pillar.href}
          />
        ))
      }
    </div>
  </div>
</section>
