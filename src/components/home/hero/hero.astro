---
import { Image } from "astro:assets";

import { getInvolvedLink } from "../../shared-content/get-involved-link";
import Button from "../../ui/button.astro";
import FacebookIcon from "./facebook-icon.astro";
import heroImage from "./hero-image.jpg";
import InstagramIcon from "./instagram-icon.astro";
import LinkedInIcon from "./linkedin-icon.astro";
---

<section class="w-full py-16">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
      <div>
        <h1
          class="font-serif text-4xl leading-[1.08] tracking-[-0.01em] text-primary sm:text-5xl lg:text-[3.5rem]"
        >
          <span class="hero-line">
            Connecting <span class="display-accent">alumni.</span>
          </span>
          <span class="hero-line">
            Amplifying <span class="display-accent">stories.</span>
          </span>
          <span class="hero-line">
            Funding <span class="display-accent">futures.</span>
          </span>
        </h1>

        <p class="mt-6 max-w-prose text-lg leading-relaxed text-primary/80">
          The central hub connecting alumni, amplifying their stories, and
          mobilizing giving to support annual MNPS initiatives and student
          scholarships.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-x-7 gap-y-4">
          <Button
            href={getInvolvedLink}
            target="_blank"
            rel="noopener noreferrer"
          >
            Join the Foundation
          </Button>

          <div class="flex items-center gap-4">
            <span
              class="text-[0.7rem] font-semibold tracking-[0.2em] text-primary/45 uppercase"
              >Follow</span
            >
            <span class="h-5 w-px bg-primary/15"></span>
            <FacebookIcon />
            <InstagramIcon />
            <LinkedInIcon />
          </div>
        </div>
      </div>

      <div>
        <Image
          src={heroImage}
          alt="MNPS graduates celebrating at Nashville's Parthenon"
          class="h-auto w-full rounded-t-[5rem] rounded-b-4xl object-cover shadow-xl ring-1 shadow-primary/10 ring-black/5"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-line {
    display: block;
  }
</style>
