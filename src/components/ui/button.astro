---
import type { HTMLAttributes } from "astro/types";

type Variant = "primary" | "secondary";

type Props = HTMLAttributes<"a"> & {
  variant?: Variant;
};

const { variant = "primary", class: className, ...rest } = Astro.props;

const base =
  "inline-flex items-center rounded-md px-6 py-3 text-sm transition-colors duration-300";

const variants: Record<Variant, string> = {
  primary: "bg-primary text-white hover:bg-secondary/80",
  secondary: "bg-white text-primary hover:bg-secondary/80",
};

const classes = [base, variants[variant], className].filter(Boolean).join(" ");
---

<a class={classes} {...rest}>
  <slot />
</a>
