---
import { getInvolvedLink } from "../shared-content/get-involved-link";
import Button from "../ui/button.astro";
---

<section class="w-full py-16">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <p class="text-sm font-semibold tracking-[0.3em] text-secondary">
        Coming Soon
      </p>
      <h1 class="mt-3 text-3xl font-bold text-primary md:text-4xl">
        Connecting Alumni
      </h1>
    </div>
    <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-primary/80">
      We're building a central hub where MNPS alumni can find local chapters,
      discover events, and stay engaged with fellow graduates across the
      district.
    </p>
    <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-primary/80">
      While this page is under construction, we'd love to hear from you. Join
      the network and share information from your local alumni chapter.
    </p>
    <div class="mt-8 text-center">
      <Button href={getInvolvedLink} target="_blank" rel="noopener noreferrer">
        Join the Alumni Network
      </Button>
    </div>
  </div>
</section>
